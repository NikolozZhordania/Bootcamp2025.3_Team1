<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="TBC Bank Cross-Browser Suite" verbose="1" parallel="tests" thread-count="2">

    <!-- CHROMIUM -->
    <test name="Desktop - Chromium">
        <parameter name="device" value="desktop"/>
        <parameter name="browser" value="chromium"/>
        <classes>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.CalendarTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.FilterLocations"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.LocationsTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.LocationsCityFilterTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.NegativeFilterTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.RandomizedLocationTests"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.CurrencyExchangeTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.QRCodeNavigationTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.OversizedInputFilterTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.WhitespaceFilterTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.LocationBranch"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.OfferTimeTravelTest"/>
        </classes>
    </test>

    <!-- FIREFOX -->
    <test name="Desktop - Firefox">
        <parameter name="device" value="desktop"/>
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.CalendarTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.FilterLocations"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.LocationsTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.LocationsCityFilterTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.NegativeFilterTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.RandomizedLocationTests"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.CurrencyExchangeTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.QRCodeNavigationTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.OversizedInputFilterTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.WhitespaceFilterTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.LocationBranch"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.OfferTimeTravelTest"/>
        </classes>
    </test>

    <!-- WEBKIT -->
    <test name="Desktop - WebKit">
        <parameter name="device" value="desktop"/>
        <parameter name="browser" value="webkit"/>
        <classes>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.CalendarTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.FilterLocations"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.LocationsTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.LocationsCityFilterTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.NegativeFilterTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.RandomizedLocationTests"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.CurrencyExchangeTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.QRCodeNavigationTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.OversizedInputFilterTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.WhitespaceFilterTest"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.LocationBranch"/>
            <class name="ge.tbc.testautomation.tbcbankapp.ui.tests.OfferTimeTravelTest"/>
        </classes>
    </test>

</suite>